generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Auth.js required models (Prisma adapter) ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  friendCode    String    @unique

  accounts             Account[]
  sessions             Session[]
  studySessions        StudySession[]
  friendshipsInitiated Friendship[]   @relation("FriendshipRequester")
  friendshipsReceived  Friendship[]   @relation("FriendshipAddressee")

  createdAt DateTime @default(now())
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// --- App models ---

enum Contest {
  AMC10
  AMC12
  AIME
  USAMO
  BMT
  SMT
}

model Friendship {
  id          String   @id @default(cuid())
  requesterId String
  addresseeId String
  createdAt   DateTime @default(now())

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([requesterId])
  @@index([addresseeId])
}

// One uploaded study session: photos of work for a given contest,
// an optional self-reported time claim, and the AI's verification result.
model StudySession {
  id      String  @id @default(cuid())
  userId  String
  contest Contest

  // Optional self-report, in 30-minute increments (e.g. 0.5, 1, 1.5 ... 8)
  claimedHours Float?

  // Public URLs of uploaded work photos (Supabase Storage)
  photoUrls String[]

  // AI verification result
  score          Int // 0-100 plausibility/effort score
  feedback       String // qualitative feedback shown to the user
  confidence     String // "low" | "medium" | "high"
  hoursPlausible Boolean? // null if no hours were claimed

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
